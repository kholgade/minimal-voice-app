# ── Google OAuth (required for login) ────────────────────────────────────────
# Create credentials at: console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL — must match what you set in GCP Console
# e.g. https://your-cloud-run-url.a.run.app/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Comma-separated list of allowed Google email addresses
ALLOWED_EMAILS=you@gmail.com
# Random secret for signing session cookies — change this to any long random string
SESSION_SECRET=change-me-to-a-random-secret

# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
STT_URL=http://localhost:3001
TTS_URL=http://localhost:3002

# LLM provider: openai | anthropic | google | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI (default provider)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini (used when LLM_PROVIDER=google)
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

TEMPERATURE=0.7
TOP_P=0.9
MAX_TOKENS=1024

TTS_VOICE=af_bella

# Local STT model (fully offline, downloaded once during setup)
# small   ~500 MB  — faster, good accuracy
# medium  ~1.5 GB  — default, high accuracy at reasonable speed
# large-v3 ~3 GB   — best accuracy, slower on CPU
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
