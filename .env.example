PORT=3000
STT_URL=http://localhost:3001
TTS_URL=http://localhost:3002

# LLM provider: openai | anthropic | google | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI (default provider)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini (used when LLM_PROVIDER=google)
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

TEMPERATURE=0.7
TOP_P=0.9
MAX_TOKENS=1024

TTS_VOICE=af_bella

# Local STT model (fully offline, downloaded once during setup)
# Options: tiny | base | small | medium | large-v3
# small = best accuracy/speed balance on CPU (~500 MB)
# medium = higher accuracy, slower on CPU (~1.5 GB)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
